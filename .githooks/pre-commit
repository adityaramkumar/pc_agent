#!/usr/bin/env bash
# Identity guard: hard-block any commit whose author is not the expected one.
# Defense in depth on top of `git config --local` set by scripts/setup-git-identity.sh.
set -euo pipefail

EXPECTED_EMAIL="ramkumar.aditya@gmail.com"
EXPECTED_NAME="adityaramkumar"

ACTUAL_EMAIL="$(git config --get user.email || true)"
ACTUAL_NAME="$(git config --get user.name  || true)"

if [[ "$ACTUAL_EMAIL" != "$EXPECTED_EMAIL" || "$ACTUAL_NAME" != "$EXPECTED_NAME" ]]; then
  echo "BLOCKED: commit identity is '$ACTUAL_NAME <$ACTUAL_EMAIL>'."
  echo "Expected '$EXPECTED_NAME <$EXPECTED_EMAIL>'."
  echo "Run scripts/setup-git-identity.sh to fix."
  exit 1
fi
